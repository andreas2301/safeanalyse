{
  "version": "2.1.0",
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "safeanalyze",
          "informationUri": "https://github.com/user/safeanalyze",
          "rules": [
            {
              "id": "PI007",
              "name": "GitHub Event Expression in AI Action Input",
              "shortDescription": {
                "text": "GitHub Event Expression in AI Action Input"
              },
              "fullDescription": {
                "text": "The AI action `openai/openai-github-action@v1` receives the GitHub event expression `${{ github.event.pull_request.body }}` via the `prompt` input parameter. While this expression may not be the highest-risk source, it could still carry attacker-controlled content (e.g. via forked repositories, external contributors, or social engineering)."
              },
              "help": {
                "text": ""
              },
              "properties": {
                "category": "prompt_injection"
              }
            },
            {
              "id": "PI010",
              "name": "Issue/Comment Body in run Step",
              "shortDescription": {
                "text": "Issue/Comment Body in run Step"
              },
              "fullDescription": {
                "text": "The ``run`` step embeds `${{ github.event.issue.title }}`, which originates from user-submitted issue or comment content. Any GitHub user can craft issue bodies or comments containing prompt injection payloads to manipulate AI agents triggered by this workflow."
              },
              "help": {
                "text": ""
              },
              "properties": {
                "category": "prompt_injection"
              }
            },
            {
              "id": "indirect_prompt_injection",
              "name": "indirect_prompt_injection",
              "shortDescription": {
                "text": "indirect_prompt_injection"
              },
              "fullDescription": {
                "text": "Content that may carry an indirect prompt-injection payload (user comment, email, web content, tool input delimiter)"
              },
              "help": {
                "text": ""
              },
              "properties": {
                "category": "pattern_match"
              }
            },
            {
              "id": "obfuscated_javascript",
              "name": "obfuscated_javascript",
              "shortDescription": {
                "text": "obfuscated_javascript"
              },
              "fullDescription": {
                "text": "Obfuscated or packed JavaScript patterns"
              },
              "help": {
                "text": ""
              },
              "properties": {
                "category": "pattern_match"
              }
            },
            {
              "id": "prompt_injection_comment",
              "name": "prompt_injection_comment",
              "shortDescription": {
                "text": "prompt_injection_comment"
              },
              "fullDescription": {
                "text": "Comment containing prompt injection keywords"
              },
              "help": {
                "text": ""
              },
              "properties": {
                "category": "pattern_match"
              }
            }
          ]
        }
